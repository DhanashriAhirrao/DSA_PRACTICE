#include <iostream>
#include<string>
using namespace std;
class student{
    public:
    string name;
    double cgpa;
    
    student(string user_name,double user_cgpa){
        this->name=user_name;
        this->cgpa=user_cgpa;
    }
    void getinfo(){
        cout<<"name : "<<name<<endl;
        cout<<"cgpa : "<<cgpa<<endl;
    }
};


int main() {
	// your code goes here
	student s1("niyamit",8.9);
	s1.getinfo();
	student s2("kripay",9.0);
	s2.getinfo();
}
